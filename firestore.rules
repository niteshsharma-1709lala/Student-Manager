rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['rollNumber', 'name', 'marks', 'honorScore', 'attendance']) &&
             data.rollNumber is string && data.rollNumber.size() > 0 && data.rollNumber.size() <= 50 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.marks is number &&
             data.honorScore is number &&
             data.attendance is number;
    }

    match /students/{studentId} {
      allow read: if true;
      allow create: if isValidId(studentId) && isValidStudent(incoming());
      allow update: if isValidId(studentId) && isValidStudent(incoming());
      allow delete: if isValidId(studentId);
    }
  }
}
